# OpenAI API Configuration
# ========================
# 
# Get your API key from: https://platform.openai.com/account/api-keys
# The API key should start with 'sk-' followed by a long string of characters
#
# SECURITY IMPORTANT: Never commit your actual API key to version control!
# Copy this file to '.env' and replace the placeholder with your real key.

OPENAI_API_KEY=your_openai_api_key_here

# Optional: API Configuration (advanced users)
# ===========================================
#
# Rate limiting (requests per minute)
# OPENAI_REQUESTS_PER_MINUTE=60
#
# Maximum retries for failed requests
# OPENAI_MAX_RETRIES=3
#
# Circuit breaker settings (number of failures before temporary shutdown)
# OPENAI_CIRCUIT_BREAKER_THRESHOLD=5
# OPENAI_CIRCUIT_BREAKER_TIMEOUT=300
#
# Request timeout (seconds)
# OPENAI_REQUEST_TIMEOUT=30
#
# Preferred model (gpt-3.5-turbo, gpt-4, etc.)
# OPENAI_DEFAULT_MODEL=gpt-3.5-turbo

# Application Settings
# ===================
# 
# Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
#
# Enable debug mode (true/false)
# DEBUG_MODE=false